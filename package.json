{
  "name": "@kaokei/use-vue-service",
  "version": "4.0.0",
  "type": "module",
  "description": "Lightweight Vue 3 state management with dependency injection, inspired by Angular services.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.cjs",
  "jsdelivr": "./dist/index.cjs",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "homepage": "https://github.com/kaokei/use-vue-service",
  "author": "kaokei",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kaokei/use-vue-service/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaokei/use-vue-service.git"
  },
  "keywords": [
    "angular",
    "vue",
    "service",
    "Ioc",
    "DI",
    "Dependency injection"
  ],
  "scripts": {
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "build": "vue-tsc -b tsconfig.app.json && vite build",
    "clean": "rm -rf dist/*",
    "public": "npm publish --access public",
    "postpublish": "git push origin --follow-tags",
    "prepublishOnly": "npm run clean && npm run build",
    "release": "standard-version -r",
    "release:first": "standard-version --first-release",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "@kaokei/di": "^5.0.4"
  },
  "devDependencies": {
    "@kaokei/di": "^5.0.4",
    "@types/node": "^22.15.17",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.1.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "standard-version": "^9.5.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.3",
    "vitepress": "^1.6.3",
    "vitest": "^3.1.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "vue-tsc": "^2.2.10",
    "@swc/core": "^1.15.21",
    "@types/fs-extra": "^11.0.4",
    "fast-check": "^4.6.0",
    "fs-extra": "^11.3.0",
    "inversify": "^6.2.2",
    "reflect-metadata": "^0.2.2",
    "unplugin-swc": "^1.5.9"
  },
  "packageManager": "pnpm@9.9.0+sha512.60c18acd138bff695d339be6ad13f7e936eea6745660d4cc4a776d5247c540d0edee1a563695c183a66eb917ef88f2b4feb1fc25f32a7adcadc7aaf3438e99c1"
}
